<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#BB86FC"
        android:title="Workout Categories"
        android:titleTextColor="@android:color/white"
        android:elevation="4dp" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/fitnessimage"
        android:src="@drawable/fitnessimage"
        android:layout_marginTop="10sp"
        android:maxWidth="100sp"
        android:maxHeight="100sp"/>

    <!-- Buttons -->
    <Button
        android:id="@+id/btnChest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chest"
        android:layout_margin="10dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back"
        android:layout_margin="10dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/btnShoulder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Shoulder"
        android:layout_margin="10dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/btnBicep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bicep"
        android:layout_margin="10dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/btnTricep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tricep"
        android:layout_margin="5dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>


    <Button
        android:id="@+id/btnLegs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Legs"
        android:layout_margin="10dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>
    <Button
        android:id="@+id/btnfit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Reminder For Workout"
        android:layout_margin="10dp"
        android:background="@drawable/rounded_button"
        android:textColor="@android:color/white"/>
</LinearLayout>